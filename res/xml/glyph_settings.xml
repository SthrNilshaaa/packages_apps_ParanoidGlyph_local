<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:title="@string/glyph_settings_title">

    <com.android.settingslib.widget.MainSwitchPreference
        android:defaultValue="false"
        android:key="glyph_enable"
        android:title="@string/glyph_settings_enable" />

    <SwitchPreferenceCompat
        android:key="glyph_settings_flip_toggle"
        android:defaultValue="true"
        android:title="@string/glyph_settings_flip_toggle_title"
        android:summary="@string/glyph_settings_flip_toggle_summary" />

    <ListPreference
        android:key="glyph_settings_flip_ringer_mode"
        android:title="@string/glyph_settings_flip_ringer_mode_title"
        android:summary="@string/glyph_settings_flip_ringer_mode_summary"
        android:entries="@array/glyph_flip_ringer_mode_entries"
        android:entryValues="@array/glyph_flip_ringer_mode_values"
        android:defaultValue="1"
        android:dependency="glyph_settings_flip_toggle" />

    <SwitchPreferenceCompat
        android:key="glyph_settings_auto_brightness_toggle"
        android:defaultValue="true"
        android:title="@string/glyph_settings_auto_brightness_toggle_title"
        android:summary="@string/glyph_settings_auto_brightness_toggle_summary" />

    <SeekBarPreference
        android:key="glyph_settings_brightness"
        android:title="@string/glyph_settings_brightness" />

    <PreferenceCategory
        android:key="glyph_settings_call"
        android:title="@string/glyph_settings_call_title" />

        <com.android.settingslib.PrimarySwitchPreference
            android:key="glyph_settings_call_toggle"
            android:defaultValue="true"
            android:title="@string/glyph_settings_call_toggle_title"
            android:summary="@string/glyph_settings_call_toggle_summary" >
            <intent android:action="android.intent.action.MAIN"
                 android:targetPackage="co.aospa.glyph"
                 android:targetClass="co.aospa.glyph.Settings.CallSettingsActivity"/>
        </com.android.settingslib.PrimarySwitchPreference>

        <SwitchPreferenceCompat
            android:key="glyph_settings_composer_enable"
            android:title="@string/glyph_settings_composer_enable_title"
            android:summary="@string/glyph_settings_composer_enable_summary"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="glyph_settings_composer_fallback"
            android:title="@string/glyph_settings_composer_fallback_title"
            android:summary="@string/glyph_settings_composer_fallback_summary"
            android:defaultValue="true"
            android:dependency="glyph_settings_composer_enable" />

        <Preference
            android:key="glyph_settings_composer_create"
            android:title="@string/glyph_settings_composer_create_title"
            android:summary="@string/glyph_settings_composer_create_summary" />

        <Preference
            android:key="glyph_settings_composer_preview"
            android:title="@string/glyph_settings_composer_preview_title"
            android:summary="@string/glyph_settings_composer_preview_summary" />

        <Preference
            android:key="glyph_settings_composer_apply"
            android:title="@string/glyph_settings_composer_apply_title"
            android:summary="@string/glyph_settings_composer_apply_summary" />

    <PreferenceCategory
        android:key="glyph_settings_notifs"
        android:title="@string/glyph_settings_notifs_title" />

        <com.android.settingslib.PrimarySwitchPreference
            android:key="glyph_settings_notifs_toggle"
            android:defaultValue="true"
            android:title="@string/glyph_settings_notifs_toggle_title"
            android:summary="@string/glyph_settings_notifs_toggle_summary" >
            <intent android:action="android.intent.action.MAIN"
                 android:targetPackage="co.aospa.glyph"
                 android:targetClass="co.aospa.glyph.Settings.NotifsSettingsActivity"/>
        </com.android.settingslib.PrimarySwitchPreference>

    <PreferenceCategory
        android:key="glyph_settings_charging"
        android:title="@string/glyph_settings_charging_title" />

        <SwitchPreferenceCompat
            android:key="glyph_settings_charging_level"
            android:defaultValue="true"
            android:title="@string/glyph_settings_charging_level_title"
            android:summary="@string/glyph_settings_charging_level_summary" />

        <SwitchPreferenceCompat
            android:key="glyph_settings_charging_powershare"
            android:defaultValue="true"
            android:title="@string/glyph_settings_charging_powershare_title"
            android:summary="@string/glyph_settings_charging_powershare_summary" />

    <PreferenceCategory
        android:key="glyph_settings_progress"
        android:title="@string/glyph_settings_progress_title" />

    <SwitchPreferenceCompat
        android:key="glyph_settings_progress_toggle"
        android:defaultValue="false"
        android:title="@string/glyph_settings_progress_toggle_title"
        android:summary="@string/glyph_settings_progress_toggle_summary" />

    <SwitchPreferenceCompat
        android:key="glyph_settings_progress_music_toggle"
        android:defaultValue="false"
        android:title="@string/glyph_settings_progress_music_toggle_title"
        android:summary="@string/glyph_settings_progress_music_toggle_summary"
        android:dependency="glyph_settings_progress_toggle" />

    <PreferenceCategory
        android:key="glyph_settings_volume"
        android:title="@string/glyph_settings_volume_title" />

        <SwitchPreferenceCompat
            android:key="glyph_settings_volume_level_toggle"
            android:defaultValue="true"
            android:title="@string/glyph_settings_volume_level_toggle_title"
            android:summary="@string/glyph_settings_volume_level_toggle_summary" />

    <PreferenceCategory
        android:key="glyph_settings_gesture"
        android:title="@string/glyph_settings_gesture_title" />

        <SwitchPreferenceCompat
            android:key="glyph_settings_shake_torch_toggle"
            android:defaultValue="false"
            android:title="@string/glyph_settings_shake_torch_toggle_title"
            android:summary="@string/glyph_settings_shake_torch_toggle_summary" />

        <SeekBarPreference
            android:key="glyph_settings_shake_sensitivity"
            android:title="@string/glyph_settings_shake_sensitivity_title"
            android:summary="@string/glyph_settings_shake_sensitivity_summary"
            android:min="20"
            android:max="55"
            android:defaultValue="35"
            android:dependency="glyph_settings_shake_torch_toggle" />

        <SeekBarPreference
            android:key="glyph_settings_shake_count"
            android:title="@string/glyph_settings_shake_count_title"
            android:summary="@string/glyph_settings_shake_count_summary"
            android:min="1"
            android:max="5"
            android:defaultValue="2"
            android:dependency="glyph_settings_shake_torch_toggle" />

        <SeekBarPreference
            android:key="glyph_settings_shake_haptic_intensity"
            android:title="@string/glyph_settings_shake_haptic_title"
            android:summary="@string/glyph_settings_shake_haptic_summary"
            android:min="0"
            android:max="100"
            android:defaultValue="50"
            android:dependency="glyph_settings_shake_torch_toggle" />

    <PreferenceCategory
        android:key="glyph_settings_misc"
        android:title="@string/glyph_settings_misc_title" />

        <Preference
            android:key="glyph_settings_schedule"
            android:title="@string/glyph_settings_schedule_title"
            android:summary="@string/glyph_settings_schedule_summary">
            <intent android:action="android.intent.action.MAIN"
                android:targetPackage="co.aospa.glyph"
                android:targetClass="co.aospa.glyph.Settings.ScheduleSettingsActivity"/>
        </Preference>

        <SwitchPreferenceCompat
            android:key="glyph_settings_music_visualizer_toggle"
            android:defaultValue="false"
            android:title="@string/glyph_settings_music_visualizer_toggle_title"
            android:summary="@string/glyph_settings_music_visualizer_toggle_summary" />

</PreferenceScreen>